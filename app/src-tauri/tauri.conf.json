{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YingDraft Companion",
  "version": "0.1.0",
  "identifier": "com.yingdraft.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YingDraft Companion",
        "width": 1180,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
